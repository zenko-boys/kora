# Copy to `.env` (gitignored).
# REST Client picks these up via {{$dotenv VAR}} in the .http files.
# docker-compose picks them up too (Auth__Authority etc.) when running `make docker-up`.

# Clerk session JWT — paste from your browser DevTools or auth.http output.
TOKEN=paste-your-clerk-jwt-here

# Clerk Backend API key (Dashboard → API Keys → Secret keys → starts with sk_test_).
# Only needed if you mint tokens headlessly via auth.http.
CLERK_SECRET_KEY=

# Clerk Frontend API URL (Dashboard → API Keys → Frontend API URL).
# Used by docker-compose to configure JWT validation.
AUTH_AUTHORITY=https://your-app.clerk.accounts.dev
AUTH_AUDIENCE=

# Auto-promote this email to Admin when they JIT-provision via Clerk.
# Set to your own email — when you sign in via Clerk, your User row will be created with Role=Admin.
AUTH_ADMIN_EMAIL=you@example.com
